{
  "name": "blinkit-scrapper",
  "version": "1.0.0",
  "description": "BlinkIt subcategory scraper supporting both Bun and Yarn",
  "main": "scrape-blinkit.ts",
  "scripts": {
    "start": "bun run scrape-blinkit.ts",
    "start:yarn": "yarn tsx scrape-blinkit.ts",
    "start:bun": "bun run scrape-blinkit.ts",
    "install:yarn": "yarn install",
    "install:bun": "bun install"
  },
  "dependencies": {
    "csv-parse": "^5.6.0"
  },
  "devDependencies": {
    "@types/node": "^22.14.1",
    "tsx": "^4.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "blinkit",
    "scraper",
    "typescript",
    "bun",
    "yarn"
  ]
}